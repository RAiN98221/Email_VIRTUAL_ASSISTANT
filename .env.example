SMTP_HOST=smtp.gmail.com
SMTP_CONNECT_HOST=
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-google-app-password
FROM_EMAIL=your-gmail-address@gmail.com

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your-gmail-address@gmail.com
IMAP_PASSWORD=your-google-app-password
VERIFY_SENT_MAIL=true
VERIFY_SENT_TIMEOUT_SECONDS=20
VERIFY_SENT_POLL_SECONDS=2

APP_DATABASE_PATH=email_assistant.sqlite3
DEFAULT_CSV_PATH=filtered_contacts_under35_male_FIXED.csv
